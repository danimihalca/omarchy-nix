#!/bin/bash

# Launch the Walker application launcher while ensuring that its data provider (elephant) is running first.

STARTED_SERVICE=false

# Ensure elephant is running before launching walker
if ! pgrep -x elephant > /dev/null; then
  setsid uwsm-app -- elephant &
  STARTED_SERVICE=true
fi

# Ensure walker service is running
if ! pgrep -f "walker --gapplication-service" > /dev/null; then
  setsid uwsm-app -- walker --gapplication-service &
  STARTED_SERVICE=true
fi

# Wait for services to be ready if we just started them
if [[ $STARTED_SERVICE == "true" ]]; then
  for i in $(seq 1 20); do
    pgrep -x elephant > /dev/null && pgrep -f "walker --gapplication-service" > /dev/null && break
    sleep 0.1
  done
fi

exec walker --width 644 --maxheight 300 --minheight 300 "$@"
